# Postgres (Docker: docker compose up -d)
DATABASE_URL="postgresql://wind:wind@localhost:5432/wind_sport"

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
# App URL (no trailing slash) — http://localhost:3000 in dev.
# Production with a custom domain: set to https://yourdomain.com (magic links use this; *.onrender.com is wrong).
# On Render without AUTH_URL, RENDER_EXTERNAL_URL (*.onrender.com) is used (see src/auth.ts).
AUTH_URL="http://localhost:3000"

# Magic links — production / Render: Resend HTTP API (same approach as fineli-ai; Render often blocks SMTP).
# https://resend.com — create API key, verify domain or use onboarding sender per Resend docs.
# RESEND_API_KEY="re_..."
# RESEND_FROM="Fjell Lift <onboarding@resend.dev>"

# Local dev: Mailpit (docker compose) via Nodemailer when RESEND_API_KEY is unset
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1025"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Fjell Lift <noreply@localhost>"

# Optional: protect cron endpoint (reserved / noop)
CRON_SECRET=""

# Optional: Open-Meteo needs no key; set for debugging
# WEATHER_DEBUG="1"

# Optional: MapTiler Outdoor vector basemap on /map (https://www.maptiler.com/)
# Without it, the app uses OSM + OpenTopoMap raster layers (no extra key).
NEXT_PUBLIC_MAPTILER_API_KEY=""

# Optional: shown on /privacy and for GDPR contact (recommended in production)
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL="privacy@yourdomain.com"
# NEXT_PUBLIC_DATA_CONTROLLER_NAME="Your Name or Company AS"
