{
  "name": "fjelllift",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/ensure-node-version.mjs && prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/ensure-node-version.mjs && prisma generate",
    "db:migrate": "node scripts/ensure-node-version.mjs && prisma migrate deploy",
    "db:dev": "node scripts/ensure-node-version.mjs && prisma migrate dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "playwright install chromium",
    "audit:dead": "knip",
    "audit:cycles": "madge --circular --extensions ts,tsx src"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@turf/bbox": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/centroid": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-map-gl": "^8.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.0",
    "@next/eslint-plugin-next": "16.2.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "knip": "^6.17.1",
    "madge": "^8.0.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "^8.5.10"
  }
}
