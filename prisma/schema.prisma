generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7: connection URL for Migrate / CLI lives in prisma.config.ts (`datasource.url`), not here.
datasource db {
  provider = "postgresql"
}

// --- Auth.js ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique @db.Citext
  emailVerified DateTime?
  image         String?
  /** Per-sport wind bands & scoring weights for forecast ranking (JSON). */
  rankingPreferences Json?

  accounts           Account[]
  sessions           Session[]
  practiceAreas      PracticeArea[]
  sessionExperiences SessionExperience[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain ---
enum Sport {
  kiteski
  kitesurf
}

enum SessionSuitability {
  unsuitable
  marginal
  suitable
  ideal
}

enum AreaLabelPreset {
  primary
  lakes
  coast
  backup
  other
}

model PracticeArea {
  id          String            @id @default(cuid())
  userId      String
  /// User-visible label on the map and in lists (max ~120 chars in API)
  name        String            @default("")
  /// GeoJSON Polygon geometry object: { type: "Polygon", coordinates: [...] }
  geojson     Json
  sports      Sport[]
  labelPreset AreaLabelPreset   @default(other)
  /// Preferred wind sectors as degrees clockwise from N, pairs [min,max] stored as Json array
  windSectors Json?
  /// Meteorological: direction wind comes from (0–360°). Boosts rank when forecast aligns; overrides global optimal when sectors are empty.
  optimalWindFromDeg Float?
  /// When true, any signed-in user can see this polygon on the map and in rankings (read-only for non-owners).
  isPublic Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  experiences SessionExperience[]

  @@index([userId])
}

/// User-logged session at a practice area (replaces Strava-linked scoring input).
model SessionExperience {
  id        String   @id @default(cuid())
  userId    String
  practiceAreaId String
  sport     Sport
  /// When the session happened (user’s local intent; stored as absolute instant).
  occurredAt DateTime
  /// How suitable conditions felt — drives experience boost when weather buckets match forecast.
  sessionSuitability SessionSuitability

  /// Open-Meteo archive (or similar) at area centroid near occurredAt
  windDirDeg   Float?
  windSpeedMs  Float?
  gustMs       Float?
  weatherProviderId  String?
  weatherObservedAt    DateTime?

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceArea PracticeArea @relation(fields: [practiceAreaId], references: [id], onDelete: Cascade)

  @@index([userId, practiceAreaId])
  @@index([userId, occurredAt])
}
